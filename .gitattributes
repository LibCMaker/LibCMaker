## Init LFS, you only need to run this once per user account:
# git lfs install
#
## To change the file:
# git lfs track "cmake/source/*.tar.*"
#
## Then:
# git add .gitattributes
# git commit ...
#
## To remove:
# git lfs untrack "cmake/source/*.tar.*"
#
#
cmake/source/*.tar.* filter=lfs diff=lfs merge=lfs -text
